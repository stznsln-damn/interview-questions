{
  "name": "test-interview",
  "type": "module",
  "version": "1.0.0",
  "description": "前端面试题知识库",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "format": "prettier --write \"**/*.md\"",
    "format:check": "prettier --check \"**/*.md\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.md": [
      "markdownlint-cli2 --fix",
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stznsln-damn/interview-questions.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/stznsln-damn/interview-questions/issues"
  },
  "homepage": "https://github.com/stznsln-damn/interview-questions#readme",
  "dependencies": {
    "@shikijs/rehype": "^4.0.1",
    "@shikijs/transformers": "^4.0.1",
    "astro": "^5.7.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1"
  }
