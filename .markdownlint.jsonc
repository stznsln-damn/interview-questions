{
  // 默认启用所有规则
  "default": true,

  // MD013 - 行长度限制，关闭（中文文档不适合硬限制行宽）
  "MD013": false,

  // MD024 - 允许不同层级下出现相同标题
  "MD024": { "siblings_only": true },

  // MD033 - 允许内联 HTML（MD 中偶尔需要 <br> 等）
  "MD033": false,

  // MD036 - 关闭"强调代替标题"检测（中文写法常见）
  "MD036": false,

  // MD041 - 第一行必须是顶级标题
  "MD041": true,

  // MD049 - 斜体风格统一用 *
  "MD049": { "style": "asterisk" },

  // MD050 - 粗体风格统一用 **
  "MD050": { "style": "asterisk" },

  // MD060 - 表格列样式，关闭（中文表格间距不统一很常见）
  "MD060": false
}
